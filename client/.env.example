# Direct API mode (recommended for teammate-host or Tailscale hostname usage)
VITE_API_URL="http://buru-degree.ts.net:5000/api"

# Optional: keep frontend using /api proxy and point Vite dev proxy at backend.
# Depending on local Vite config behavior, this may also be set via shell env.
# VITE_PROXY_TARGET="http://buru-degree.ts.net:5000"
# Local override example: VITE_API_URL="http://localhost:5000/api"

# Google Identity Services client ID for Continue with Google.
VITE_GOOGLE_CLIENT_ID=""
