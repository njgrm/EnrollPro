generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// System users: registrars and system administrators who manage the enrollment process
model User {
  id                 Int          @id @default(autoincrement())
  firstName          String       @map("first_name")
  lastName           String       @map("last_name")
  middleName         String?      @map("middle_name")
  suffix             String?
  sex                Sex          @default(FEMALE)
  employeeId         String?      @unique(map: "uq_users_employee_id") @map("employee_id")
  designation        String?
  mobileNumber       String?      @map("mobile_number")
  email              String       @unique(map: "uq_users_email")
  password           String
  role               Role
  isActive           Boolean      @default(true) @map("is_active")
  lastLoginAt        DateTime?    @db.Timestamptz @map("last_login_at")
  mustChangePassword Boolean      @default(false) @map("must_change_password")
  createdById        Int?         @map("created_by_id")
  createdAt          DateTime     @default(now()) @db.Timestamptz @map("created_at")
  updatedAt          DateTime     @updatedAt @db.Timestamptz @map("updated_at")
  encodedApplicants  Applicant[]  @relation("ApplicantEncodedBy")
  auditLogs          AuditLog[]
  enrollments        Enrollment[]
  createdBy          User?        @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers       User[]       @relation("UserCreatedBy")
  uploadedDocuments  Document[]   @relation("DocumentUploadedBy")
  updatedChecklists  RequirementChecklist[]
  recordedHealthRecords HealthRecord[] @relation("HealthRecordRecordedBy")

  @@map("users")
}

/// Faculty members who serve as section advisers; not login users
model Teacher {
  id             Int       @id @default(autoincrement())
  employeeId     String?   @unique(map: "uq_teachers_employee_id") @map("employee_id")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  middleName     String?   @map("middle_name")
  email          String?   @map("email")
  contactNumber  String?   @map("contact_number")
  specialization String?
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @db.Timestamptz @map("created_at")
  updatedAt      DateTime         @updatedAt @db.Timestamptz @map("updated_at")
  sections       Section[]
  subjects       TeacherSubject[]

  @@map("teachers")
}

/// Singleton config: school identity (name, logo, accent color) and active school year pointer
model SchoolSettings {
  id                   Int           @id @default(autoincrement())
  schoolName           String        @map("school_name")
  logoPath             String?       @map("logo_path")
  logoUrl              String?       @map("logo_url")
  colorScheme          Json?         @map("color_scheme")
  selectedAccentHsl    String?       @map("selected_accent_hsl")
  activeSchoolYearId   Int?          @map("active_school_year_id")
  activeSchoolYear     SchoolYear?   @relation(fields: [activeSchoolYearId], references: [id])

  @@map("school_settings")
}

/// Academic year with enrollment window dates and lifecycle status (DRAFT → UPCOMING → ACTIVE → ARCHIVED)
model SchoolYear {
  id                 Int              @id @default(autoincrement())
  yearLabel          String           @unique(map: "uq_school_years_year_label") @map("year_label")
  status             SchoolYearStatus @default(DRAFT)
  isActive           Boolean          @default(false) @map("is_active")
  classOpeningDate   DateTime?        @db.Date @map("class_opening_date")
  classEndDate       DateTime?        @db.Date @map("class_end_date")
  earlyRegOpenDate   DateTime?        @db.Date @map("early_reg_open_date")
  earlyRegCloseDate  DateTime?        @db.Date @map("early_reg_close_date")
  enrollOpenDate     DateTime?        @db.Date @map("enroll_open_date")
  enrollCloseDate    DateTime?        @db.Date @map("enroll_close_date")
  isManualOverrideOpen Boolean        @default(false) @map("is_manual_override_open")
  clonedFromId       Int?             @map("cloned_from_id")
  createdAt          DateTime         @default(now()) @db.Timestamptz @map("created_at")
  clonedFrom         SchoolYear?      @relation("SchoolYearClone", fields: [clonedFromId], references: [id])
  clones             SchoolYear[]     @relation("SchoolYearClone")
  applicants         Applicant[]
  enrollments        Enrollment[]
  gradeLevels        GradeLevel[]
  schoolSettings     SchoolSettings[]
  scpConfigs         ScpConfig[]
  strands            Strand[]
  healthRecords      HealthRecord[]

  @@map("school_years")
}

/// K-12 grade levels (e.g. Grade 7, Grade 11) cloned per school year
model GradeLevel {
  id             Int          @id @default(autoincrement())
  name           String
  displayOrder   Int          @map("display_order")
  schoolYearId   Int          @map("school_year_id")
  createdAt      DateTime     @default(now()) @db.Timestamptz @map("created_at")
  applicants     Applicant[]
  schoolYear     SchoolYear   @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  sections       Section[]
  strands        StrandGradeLevel[]

  @@map("grade_levels")
}

/// SHS academic tracks/strands (e.g. STEM, ABM) and elective clusters, cloned per school year
model Strand {
  id                      Int              @id @default(autoincrement())
  name                    String
  schoolYearId            Int              @map("school_year_id")
  curriculumType          CurriculumType   @default(OLD_STRAND) @map("curriculum_type")
  track                   SHSTrack?
  createdAt               DateTime         @default(now()) @db.Timestamptz @map("created_at")
  applicants              Applicant[]
  schoolYear              SchoolYear       @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  gradeLevels             StrandGradeLevel[]

  @@map("strands")
}

/// Class section with capacity, grade level, and optional advising teacher
model Section {
  id                Int          @id @default(autoincrement())
  name              String
  maxCapacity       Int          @default(40) @map("max_capacity")
  gradeLevelId      Int          @map("grade_level_id")
  advisingTeacherId Int?         @map("advising_teacher_id")
  createdAt         DateTime     @default(now()) @db.Timestamptz @map("created_at")
  updatedAt         DateTime     @updatedAt @db.Timestamptz @map("updated_at")
  enrollments       Enrollment[]
  advisingTeacher   Teacher?     @relation(fields: [advisingTeacherId], references: [id])
  gradeLevel        GradeLevel   @relation(fields: [gradeLevelId], references: [id], onDelete: Cascade)

  @@map("sections")
}

/// Central entity: a student application through the admission pipeline (SUBMITTED → ... → ENROLLED)
model Applicant {
  id                      Int               @id @default(autoincrement())
  studentPhoto            String?           @map("student_photo")
  lrn                     String?           @db.VarChar(12)
  psaBirthCertNumber      String?           @map("psa_birth_cert_number")
  lastName                String            @map("last_name")
  firstName               String            @map("first_name")
  middleName              String?           @map("middle_name")
  suffix                  String?
  birthDate               DateTime          @db.Date @map("birth_date")
  sex                     Sex
  placeOfBirth            String?           @map("place_of_birth")
  religion                String?
  motherTongue            String?           @map("mother_tongue")
  emailAddress            String?           @map("email_address")
  isIpCommunity           Boolean           @default(false) @map("is_ip_community")
  ipGroupName             String?           @map("ip_group_name")
  is4PsBeneficiary        Boolean           @default(false) @map("is_4ps_beneficiary")
  householdId4Ps          String?           @map("household_id_4ps")
  isBalikAral             Boolean           @default(false) @map("is_balik_aral")
  lastYearEnrolled        String?           @map("last_year_enrolled")
  isLearnerWithDisability Boolean           @default(false) @map("is_learner_with_disability")
  disabilityTypes         String[]          @map("disability_types")
  learnerType             LearnerType       @default(NEW_ENROLLEE) @map("learner_type")
  electiveCluster         String?           @map("elective_cluster")
  trackingNumber          String            @unique(map: "uq_applicants_tracking_number") @map("tracking_number")
  status                  ApplicationStatus @default(SUBMITTED)
  rejectionReason         String?           @map("rejection_reason")
  gradeLevelId            Int               @map("grade_level_id")
  strandId                Int?              @map("strand_id")
  schoolYearId            Int               @map("school_year_id")
  applicantType           ApplicantType     @default(REGULAR) @map("applicant_type")
  shsTrack                SHSTrack?         @map("shs_track")
  isPrivacyConsentGiven   Boolean           @default(false) @map("is_privacy_consent_given")
  createdAt               DateTime          @default(now()) @db.Timestamptz @map("created_at")
  updatedAt               DateTime          @updatedAt @db.Timestamptz @map("updated_at")
  admissionChannel        AdmissionChannel  @default(ONLINE) @map("admission_channel")
  encodedById             Int?              @map("encoded_by_id")
  specialNeedsCategory    String?           @map("special_needs_category")
  hasPwdId                Boolean           @default(false) @map("has_pwd_id")
  learningModalities      String[]          @map("learning_modalities")
  isTemporarilyEnrolled   Boolean           @default(false) @map("is_temporarily_enrolled")
  portalPin               String?           @map("portal_pin")
  portalPinChangedAt      DateTime?         @db.Timestamptz @map("portal_pin_changed_at")
  schoolYear              SchoolYear        @relation(fields: [schoolYearId], references: [id])
  encodedBy               User?             @relation("ApplicantEncodedBy", fields: [encodedById], references: [id])
  gradeLevel              GradeLevel        @relation(fields: [gradeLevelId], references: [id])
  strand                  Strand?           @relation(fields: [strandId], references: [id])
  addresses               ApplicantAddress[]
  familyMembers           ApplicantFamilyMember[]
  previousSchool          PreviousSchool?
  assessments             Assessment[]
  scpDetail               ScpDetail?
  documents               Document[]
  checklist               RequirementChecklist?
  emailLogs               EmailLog[]
  enrollment              Enrollment?
  healthRecords           HealthRecord[]

  @@index([status, schoolYearId], name: "idx_applicants_status_school_year_id")
  @@index([lrn], name: "idx_applicants_lrn")
  @@index([applicantType, status], name: "idx_applicants_type_status")
  @@index([trackingNumber], name: "idx_applicants_tracking_number")
  @@map("applicants")
}

/// Applicant address: current or permanent, extracted from JSON for queryability
model ApplicantAddress {
  id               Int         @id @default(autoincrement())
  applicantId      Int         @map("applicant_id")
  addressType      AddressType @map("address_type")
  houseNo          String?     @map("house_no")
  street           String?
  barangay         String?
  cityMunicipality String?     @map("city_municipality")
  province         String?
  country          String?     @default("PHILIPPINES")
  zipCode          String?     @map("zip_code")
  applicant        Applicant   @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([applicantId, addressType], name: "uq_applicant_addresses_type")
  @@index([applicantId], name: "idx_applicant_addresses_applicant_id")
  @@map("applicant_addresses")
}

/// Parent/guardian info extracted from JSON for relational querying and DepEd reporting
model ApplicantFamilyMember {
  id             Int                @id @default(autoincrement())
  applicantId    Int                @map("applicant_id")
  relationship   FamilyRelationship
  firstName      String             @map("first_name")
  lastName       String             @map("last_name")
  middleName     String?            @map("middle_name")
  contactNumber  String?            @map("contact_number")
  email          String?
  occupation     String?
  applicant      Applicant          @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([applicantId, relationship], name: "uq_applicant_family_members_rel")
  @@index([applicantId], name: "idx_applicant_family_members_applicant_id")
  @@map("applicant_family_members")
}

/// Previous school record with academic grades, extracted from Applicant for 3NF
model PreviousSchool {
  id                  Int       @id @default(autoincrement())
  applicantId         Int       @unique(map: "uq_previous_schools_applicant_id") @map("applicant_id")
  schoolName          String?   @map("school_name")
  schoolDepedId       String?   @map("school_deped_id")
  gradeCompleted      String?   @map("grade_completed")
  schoolYearAttended  String?   @map("school_year_attended")
  schoolAddress       String?   @map("school_address")
  schoolType          String?   @map("school_type")
  natScore            Float?    @map("nat_score")
  grade10ScienceGrade Float?    @map("grade10_science_grade")
  grade10MathGrade    Float?    @map("grade10_math_grade")
  generalAverage      Float?    @map("general_average")
  applicant           Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@map("previous_schools")
}

/// Assessment event (exam, interview, audition, tryout) — 1:many with Applicant for reschedules
model Assessment {
  id            Int            @id @default(autoincrement())
  applicantId   Int            @map("applicant_id")
  type          AssessmentKind @map("assessment_kind")
  scheduledDate DateTime?      @db.Date @map("scheduled_date")
  scheduledTime String?        @map("scheduled_time")
  venue         String?
  score         Float?
  result        String?
  notes         String?
  conductedAt   DateTime?      @db.Timestamptz @map("conducted_at")
  createdAt     DateTime       @default(now()) @db.Timestamptz @map("created_at")
  applicant     Applicant      @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([applicantId], name: "idx_assessments_applicant_id")
  @@index([applicantId, type], name: "idx_assessments_applicant_type")
  @@map("assessments")
}

/// SCP-specific details, only present for Special Curricular Program applicants
model ScpDetail {
  id              Int           @id @default(autoincrement())
  applicantId     Int           @unique(map: "uq_scp_details_applicant_id") @map("applicant_id")
  scpType         ApplicantType @map("scp_type")
  artField        String?       @map("art_field")
  foreignLanguage String?       @map("foreign_language")
  sportsList      String[]      @map("sports_list")
  applicant       Applicant     @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@map("scp_details")
}

/// Uploaded documentary requirements (PSA, SF9, etc.) attached to an applicant
model Document {
  id               Int            @id @default(autoincrement())
  applicantId      Int            @map("applicant_id")
  documentType     DocumentType   @map("document_type")
  status           DocumentStatus @default(SUBMITTED)
  fileName         String?        @map("file_name")
  originalName     String?        @map("original_name")
  mimeType         String?        @map("mime_type")
  size             Int?
  verificationNote String?        @map("verification_note")
  isPresentedOnly  Boolean        @default(false) @map("is_presented_only")
  uploadedAt       DateTime       @default(now()) @db.Timestamptz @map("uploaded_at")
  uploadedById     Int?           @map("uploaded_by_id")
  verifiedAt       DateTime?      @db.Timestamptz @map("verified_at")
  verifiedById     Int?           @map("verified_by_id")
  applicant        Applicant      @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  uploadedBy       User?          @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])

  @@index([applicantId], name: "idx_documents_applicant_id")
  @@map("documents")
}

/// DepEd documentary requirement checklist per applicant (presented/collected flags)
model RequirementChecklist {
  id                                 Int       @id @default(autoincrement())
  applicantId                        Int       @unique(map: "uq_requirement_checklists_applicant_id") @map("applicant_id")
  isPsaBirthCertPresented            Boolean   @default(false) @map("is_psa_birth_cert_presented")
  isOriginalPsaBcCollected           Boolean   @default(false) @map("is_original_psa_bc_collected")
  isSf9Submitted                     Boolean   @default(false) @map("is_sf9_submitted")
  isSf10Requested                    Boolean   @default(false) @map("is_sf10_requested")
  isGoodMoralPresented               Boolean   @default(false) @map("is_good_moral_presented")
  isMedicalEvalSubmitted             Boolean   @default(false) @map("is_medical_eval_submitted")
  isUndertakingSigned                Boolean   @default(false) @map("is_undertaking_signed")
  isConfirmationSlipReceived         Boolean   @default(false) @map("is_confirmation_slip_received")
  updatedAt                          DateTime  @updatedAt @db.Timestamptz @map("updated_at")
  updatedById                        Int?      @map("updated_by_id")
  applicant                          Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  updatedBy                          User?     @relation(fields: [updatedById], references: [id])

  @@map("requirement_checklists")
}

/// Final enrollment record linking an approved applicant to a section in a school year
model Enrollment {
  id             Int          @id @default(autoincrement())
  applicantId    Int          @unique(map: "uq_enrollments_applicant_id") @map("applicant_id")
  sectionId      Int          @map("section_id")
  schoolYearId   Int          @map("school_year_id")
  enrolledAt     DateTime     @default(now()) @db.Timestamptz @map("enrolled_at")
  enrolledById   Int          @map("enrolled_by_id")
  schoolYear     SchoolYear   @relation(fields: [schoolYearId], references: [id])
  applicant      Applicant    @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  enrolledBy     User         @relation(fields: [enrolledById], references: [id])
  section        Section      @relation(fields: [sectionId], references: [id])

  @@map("enrollments")
}

/// Academic department (future use)
model Department {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique(map: "uq_departments_code")
  description String?
  createdAt   DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz @map("updated_at")

  @@map("departments")
}

/// Immutable audit trail of all system actions with actor, IP, and user-agent
model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  actionType  String   @map("action_type")
  description String
  subjectType String?  @map("subject_type")
  recordId    Int?     @map("record_id")
  ipAddress   String   @db.VarChar(45) @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @db.Timestamptz @map("created_at")
  user        User?    @relation(fields: [userId], references: [id])

  @@index([actionType], name: "idx_audit_logs_action_type")
  @@index([createdAt], name: "idx_audit_logs_created_at")
  @@map("audit_logs")
}

/// Transactional email log tracking delivery status to applicant email addresses
model EmailLog {
  id           Int          @id @default(autoincrement())
  recipient    String
  subject      String
  trigger      EmailTrigger
  status       EmailStatus  @default(PENDING)
  applicantId  Int?         @map("applicant_id")
  errorMessage String?      @map("error_message")
  attemptedAt  DateTime     @default(now()) @db.Timestamptz @map("attempted_at")
  sentAt       DateTime?    @db.Timestamptz @map("sent_at")
  applicant    Applicant?   @relation(fields: [applicantId], references: [id])

  @@index([status], name: "idx_email_logs_status")
  @@index([trigger], name: "idx_email_logs_trigger")
  @@map("email_logs")
}

/// Student health measurement (SF8): weight, height per assessment period (BOSY/EOSY)
model HealthRecord {
  id               Int              @id @default(autoincrement())
  applicantId      Int              @map("applicant_id")
  schoolYearId     Int              @map("school_year_id")
  assessmentPeriod AssessmentPeriod @map("assessment_period")
  assessmentDate   DateTime         @db.Date @map("assessment_date")
  weightKg         Float            @map("weight_kg")
  heightCm         Float            @map("height_cm")
  notes            String?
  recordedById     Int              @map("recorded_by_id")
  createdAt        DateTime         @default(now()) @db.Timestamptz @map("created_at")
  updatedAt        DateTime         @updatedAt @db.Timestamptz @map("updated_at")

  applicant  Applicant  @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  schoolYear SchoolYear @relation(fields: [schoolYearId], references: [id])
  recordedBy User       @relation("HealthRecordRecordedBy", fields: [recordedById], references: [id])

  @@unique([applicantId, schoolYearId, assessmentPeriod], name: "uq_health_records_period")
  @@index([applicantId])
  @@index([applicantId, schoolYearId])
  @@map("health_records")
}

/// Special Curricular Program configuration per school year and applicant type
model ScpConfig {
  id             Int             @id @default(autoincrement())
  schoolYearId   Int             @map("school_year_id")
  scpType        ApplicantType   @map("scp_type")
  isOffered      Boolean         @default(false) @map("is_offered")
  cutoffScore    Float?          @map("cutoff_score")
  assessmentType String?         @map("assessment_type")
  examDate       DateTime?       @db.Date @map("exam_date")
  examTime       String?         @map("exam_time")
  notes          String?
  schoolYear     SchoolYear      @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  options        ScpConfigOption[]

  @@unique([schoolYearId, scpType], name: "uq_scp_configs_school_year_scp_type")
  @@map("scp_configs")
}

/// Options for SCP configuration: art fields, languages, and sports per SCP config
model ScpConfigOption {
  id          Int           @id @default(autoincrement())
  scpConfigId Int           @map("scp_config_id")
  optionType  ScpOptionType @map("option_type")
  value       String
  scpConfig   ScpConfig     @relation(fields: [scpConfigId], references: [id], onDelete: Cascade)

  @@unique([scpConfigId, optionType, value], name: "uq_scp_config_options_type_value")
  @@index([scpConfigId], name: "idx_scp_config_options_config_id")
  @@map("scp_config_options")
}

/// Junction table linking strands to applicable grade levels (replaces Int[] for referential integrity)
model StrandGradeLevel {
  strandId     Int        @map("strand_id")
  gradeLevelId Int        @map("grade_level_id")
  strand       Strand     @relation(fields: [strandId], references: [id], onDelete: Cascade)
  gradeLevel   GradeLevel @relation(fields: [gradeLevelId], references: [id], onDelete: Cascade)

  @@id([strandId, gradeLevelId])
  @@map("strand_grade_levels")
}

/// Teacher subject specializations, extracted from String[] for 1NF compliance
model TeacherSubject {
  id        Int     @id @default(autoincrement())
  teacherId Int     @map("teacher_id")
  subject   String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subject], name: "uq_teacher_subjects_teacher_subject")
  @@index([teacherId], name: "idx_teacher_subjects_teacher_id")
  @@map("teacher_subjects")
}

/// User role: REGISTRAR handles enrollment; SYSTEM_ADMIN has full access
enum Role {
  REGISTRAR
  SYSTEM_ADMIN

  @@map("user_role")
}

/// Biological sex per DepEd SF1
enum Sex {
  MALE
  FEMALE

  @@map("sex")
}

/// Admission pipeline stages from initial submission through final enrollment
enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  FOR_REVISION
  ELIGIBLE
  EXAM_SCHEDULED
  ASSESSMENT_SCHEDULED
  ASSESSMENT_TAKEN
  PASSED
  PRE_REGISTERED
  TEMPORARILY_ENROLLED
  NOT_QUALIFIED
  ENROLLED
  REJECTED
  WITHDRAWN

  @@map("application_status")
}

/// School year lifecycle: DRAFT (config) → UPCOMING (visible) → ACTIVE (current) → ARCHIVED
enum SchoolYearStatus {
  DRAFT
  UPCOMING
  ACTIVE
  ARCHIVED

  @@map("school_year_status")
}

/// SHS curriculum types per MATATAG/K-12 reforms
enum CurriculumType {
  OLD_STRAND
  ELECTIVE_CLUSTER

  @@map("curriculum_type")
}

/// SHS tracks: Academic or Technical-Professional
enum SHSTrack {
  ACADEMIC
  TECHPRO

  @@map("shs_track")
}

/// Enrollment classification: REGULAR standard admission, Special Curricular Programs
enum ApplicantType {
  REGULAR
  SCIENCE_TECHNOLOGY_AND_ENGINEERING
  SPECIAL_PROGRAM_IN_THE_ARTS
  SPECIAL_PROGRAM_IN_SPORTS
  SPECIAL_PROGRAM_IN_JOURNALISM
  SPECIAL_PROGRAM_IN_FOREIGN_LANGUAGE
  SPECIAL_PROGRAM_IN_TECHNICAL_VOCATIONAL_EDUCATION
  STEM_GRADE_11

  @@map("applicant_type")
}

/// Events that trigger automated email notifications
enum EmailTrigger {
  APPLICATION_SUBMITTED
  APPLICATION_APPROVED
  APPLICATION_REJECTED
  EXAM_SCHEDULED
  ASSESSMENT_PASSED
  ASSESSMENT_FAILED

  @@map("email_trigger")
}

/// Email delivery status
enum EmailStatus {
  PENDING
  SENT
  FAILED

  @@map("email_status")
}

/// How the application was submitted: ONLINE (self-service) or F2F (registrar-encoded)
enum AdmissionChannel {
  ONLINE
  F2F

  @@map("admission_channel")
