generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows"]
  output = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// System users: registrars and system administrators who manage the enrollment process
model User {
  id                 Int          @id @default(autoincrement())
  firstName          String       @map("first_name")
  lastName           String       @map("last_name")
  middleName         String?      @map("middle_name")
  suffix             String?
  sex                Sex          @default(FEMALE)
  employeeId         String?      @unique(map: "uq_users_employee_id") @map("employee_id")
  designation        String?
  mobileNumber       String?      @map("mobile_number")
  email              String       @unique(map: "uq_users_email")
  password           String
  role               Role
  isActive           Boolean      @default(true) @map("is_active")
  lastLoginAt        DateTime?    @db.Timestamptz @map("last_login_at")
  mustChangePassword Boolean      @default(false) @map("must_change_password")
  createdById        Int?         @map("created_by_id")
  createdAt          DateTime     @default(now()) @db.Timestamptz @map("created_at")
  updatedAt          DateTime     @updatedAt @db.Timestamptz @map("updated_at")
  
  encodedApplicants  Applicant[]  @relation("ApplicantEncodedBy")
  auditLogs          AuditLog[]
  enrollments        Enrollment[]
  createdBy          User?        @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers       User[]       @relation("UserCreatedBy")
  uploadedDocuments  ApplicantDocument[]   @relation("DocumentUploadedBy")
  verifiedDocuments  ApplicantDocument[]   @relation("DocumentVerifiedBy")
  updatedChecklists  ApplicantChecklist[]
  recordedHealthRecords HealthRecord[] @relation("HealthRecordRecordedBy")
  encodedEarlyRegs      EarlyRegistration[] @relation("EarlyRegEncodedBy")
  verifiedEarlyRegs     EarlyRegistration[] @relation("EarlyRegVerifiedBy")

  @@map("users")
}

/// Faculty members who serve as section advisers; not login users
model Teacher {
  id             Int       @id @default(autoincrement())
  employeeId     String?   @unique(map: "uq_teachers_employee_id") @map("employee_id")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  middleName     String?   @map("middle_name")
  email          String?   @map("email")
  contactNumber  String?   @map("contact_number")
  specialization String?
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @db.Timestamptz @map("created_at")
  updatedAt      DateTime         @updatedAt @db.Timestamptz @map("updated_at")
  
  sections       Section[]
  subjects       TeacherSubject[]

  @@map("teachers")
}

/// Singleton config: school identity (name, logo, accent color) and active school year pointer
model SchoolSetting {
  id                   Int           @id @default(autoincrement())
  schoolName           String        @map("school_name")
  logoPath             String?       @map("logo_path")
  logoUrl              String?       @map("logo_url")
  colorScheme          Json?         @map("color_scheme")
  selectedAccentHsl    String?       @map("selected_accent_hsl")
  activeSchoolYearId   Int?          @map("active_school_year_id")
  
  activeSchoolYear     SchoolYear?   @relation(fields: [activeSchoolYearId], references: [id])

  @@map("school_settings")
}

/// Academic year with enrollment window dates and lifecycle status
model SchoolYear {
  id                 Int              @id @default(autoincrement())
  yearLabel          String           @unique(map: "uq_school_years_year_label") @map("year_label")
  status             SchoolYearStatus @default(DRAFT)
  classOpeningDate   DateTime?        @db.Date @map("class_opening_date")
  classEndDate       DateTime?        @db.Date @map("class_end_date")
  earlyRegOpenDate   DateTime?        @db.Date @map("early_reg_open_date")
  earlyRegCloseDate  DateTime?        @db.Date @map("early_reg_close_date")
  enrollOpenDate     DateTime?        @db.Date @map("enroll_open_date")
  enrollCloseDate    DateTime?        @db.Date @map("enroll_close_date")
  isManualOverrideOpen Boolean        @default(false) @map("is_manual_override_open")
  clonedFromId       Int?             @map("cloned_from_id")
  createdAt          DateTime         @default(now()) @db.Timestamptz @map("created_at")
  
  clonedFrom         SchoolYear?      @relation("SchoolYearClone", fields: [clonedFromId], references: [id])
  clones             SchoolYear[]     @relation("SchoolYearClone")
  applicants         Applicant[]
  enrollments        Enrollment[]
  gradeLevels        GradeLevel[]
  schoolSettings     SchoolSetting[]
  scpProgramConfigs  ScpProgramConfig[]
  healthRecords      HealthRecord[]
  earlyRegistrations EarlyRegistration[]

  @@map("school_years")
}

/// JHS grade levels (e.g. Grade 7, Grade 10) cloned per school year
model GradeLevel {
  id             Int          @id @default(autoincrement())
  name           String
  displayOrder   Int          @map("display_order")
  schoolYearId   Int          @map("school_year_id")
  createdAt      DateTime     @default(now()) @db.Timestamptz @map("created_at")
  
  applicants     Applicant[]
  schoolYear     SchoolYear   @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  sections       Section[]
  earlyRegistrationsV2 EarlyRegistration[]

  @@index([schoolYearId], name: "idx_grade_levels_school_year_id")
  @@map("grade_levels")
}

/// Class section with capacity, grade level, and optional advising teacher
model Section {
  id                Int          @id @default(autoincrement())
  name              String
  maxCapacity       Int          @default(40) @map("max_capacity")
  gradeLevelId      Int          @map("grade_level_id")
  advisingTeacherId Int?         @map("advising_teacher_id")
  createdAt         DateTime     @default(now()) @db.Timestamptz @map("created_at")
  updatedAt         DateTime     @updatedAt @db.Timestamptz @map("updated_at")
  
  enrollments       Enrollment[]
  advisingTeacher   Teacher?     @relation(fields: [advisingTeacherId], references: [id])
  gradeLevel        GradeLevel   @relation(fields: [gradeLevelId], references: [id], onDelete: Cascade)

  @@index([gradeLevelId], name: "idx_sections_grade_level_id")
  @@map("sections")
}

/// Central entity: a student application through the admission pipeline
model Applicant {
  id                      Int               @id @default(autoincrement())
  studentPhoto            String?           @map("student_photo")
  lrn                     String?           @db.VarChar(12)
  psaBirthCertNumber      String?           @map("psa_birth_cert_number")
  lastName                String            @map("last_name")
  firstName               String            @map("first_name")
  middleName              String?           @map("middle_name")
  suffix                  String?
  birthDate               DateTime          @db.Date @map("birth_date")
  sex                     Sex
  placeOfBirth            String?           @map("place_of_birth")
  religion                String?
  motherTongue            String?           @map("mother_tongue")
  emailAddress            String?           @map("email_address")
  isIpCommunity           Boolean           @default(false) @map("is_ip_community")
  ipGroupName             String?           @map("ip_group_name")
  is4PsBeneficiary        Boolean           @default(false) @map("is_4ps_beneficiary")
  householdId4Ps          String?           @map("household_id_4ps")
  isBalikAral             Boolean           @default(false) @map("is_balik_aral")
  lastYearEnrolled        String?           @map("last_year_enrolled")
  isLearnerWithDisability Boolean           @default(false) @map("is_learner_with_disability")
  disabilityTypes         String[]          @map("disability_types")
  learnerType             LearnerType       @default(NEW_ENROLLEE) @map("learner_type")
  trackingNumber          String            @unique(map: "uq_applicants_tracking_number") @map("tracking_number")
  status                  ApplicationStatus @default(SUBMITTED)
  rejectionReason         String?           @map("rejection_reason")
  gradeLevelId            Int               @map("grade_level_id")
  schoolYearId            Int               @map("school_year_id")
  applicantType           ApplicantType     @default(REGULAR) @map("applicant_type")
  isPrivacyConsentGiven   Boolean           @default(false) @map("is_privacy_consent_given")
  createdAt               DateTime          @default(now()) @db.Timestamptz @map("created_at")
  updatedAt               DateTime          @updatedAt @db.Timestamptz @map("updated_at")
  admissionChannel        AdmissionChannel  @default(ONLINE) @map("admission_channel")
  encodedById             Int?              @map("encoded_by_id")
  specialNeedsCategory    String?           @map("special_needs_category")
  hasPwdId                Boolean           @default(false) @map("has_pwd_id")
  learningModalities      String[]          @map("learning_modalities")
  isTemporarilyEnrolled   Boolean           @default(false) @map("is_temporarily_enrolled")
  documentaryDeadlineAt   DateTime?         @db.Date @map("documentary_deadline_at")
  complianceStatus        ComplianceStatus? @map("compliance_status")
  portalPin               String?           @map("portal_pin")
  portalPinChangedAt      DateTime?         @db.Timestamptz @map("portal_pin_changed_at")
  
  schoolYear              SchoolYear        @relation(fields: [schoolYearId], references: [id])
  encodedBy               User?             @relation("ApplicantEncodedBy", fields: [encodedById], references: [id])
  gradeLevel              GradeLevel        @relation(fields: [gradeLevelId], references: [id])
  addresses               ApplicantAddress[]
  familyMembers           ApplicantFamilyMember[]
  previousSchool          ApplicantPreviousSchool?
  assessments             ApplicantAssessment[]
  programDetail           ApplicantProgramDetail?
  documents               ApplicantDocument[]
  checklist               ApplicantChecklist?
  emailLogs               EmailLog[]
  enrollment              Enrollment?
  healthRecords           HealthRecord[]
  earlyRegistrations      EarlyRegistration[]

  @@index([status, schoolYearId], name: "idx_applicants_status_sy")
  @@index([status, documentaryDeadlineAt], name: "idx_applicants_status_deadline")
  @@index([lrn], name: "idx_applicants_lrn")
  @@index([applicantType, status], name: "idx_applicants_type_status")
  @@index([applicantType, status, schoolYearId], name: "idx_applicants_type_status_sy")
  @@index([trackingNumber], name: "idx_applicants_tracking_no")
  @@index([encodedById], name: "idx_applicants_encoded_by")
  @@map("applicants")
}

/// Applicant address: current or permanent
model ApplicantAddress {
  id               Int         @id @default(autoincrement())
  applicantId      Int         @map("applicant_id")
  addressType      AddressType @map("address_type")
  houseNo          String?     @map("house_no")
  street           String?
  barangay         String?
  cityMunicipality String?     @map("city_municipality")
  province         String?
  country          String?     @default("PHILIPPINES")
  zipCode          String?     @map("zip_code")
  
  applicant        Applicant   @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([applicantId, addressType], name: "uq_applicant_addresses_type")
  @@index([applicantId], name: "idx_applicant_addresses_applicant_id")
  @@map("applicant_addresses")
}

/// Parent/guardian info extracted from JSON for relational querying and DepEd reporting
model ApplicantFamilyMember {
  id             Int                @id @default(autoincrement())
  applicantId    Int                @map("applicant_id")
  relationship   FamilyRelationship
  firstName      String             @map("first_name")
  lastName       String             @map("last_name")
  middleName     String?            @map("middle_name")
  contactNumber  String?            @map("contact_number")
  email          String?
  occupation     String?
  
  applicant      Applicant          @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([applicantId, relationship], name: "uq_applicant_family_members_rel")
  @@index([applicantId], name: "idx_applicant_family_members_applicant_id")
  @@map("applicant_family_members")
}

/// Previous school record with academic grades
model ApplicantPreviousSchool {
  id                  Int       @id @default(autoincrement())
  applicantId         Int       @unique(map: "uq_applicant_previous_schools_id") @map("applicant_id")
  schoolName          String?   @map("school_name")
  schoolDepedId       String?   @map("school_deped_id")
  gradeCompleted      String?   @map("grade_completed")
  schoolYearAttended  String?   @map("school_year_attended")
  schoolAddress       String?   @map("school_address")
  schoolType          String?   @map("school_type")
  natScore            Float?    @map("nat_score")
  grade10ScienceGrade Float?    @map("grade10_science_grade")
  grade10MathGrade    Float?    @map("grade10_math_grade")
  generalAverage      Float?    @map("general_average")
  
  applicant           Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@map("applicant_previous_schools")
}

/// Assessment event (exam, interview, audition, tryout) — 1:many with Applicant for reschedules
model ApplicantAssessment {
  id            Int            @id @default(autoincrement())
  applicantId   Int            @map("applicant_id")
  type          AssessmentKind @map("assessment_kind")
  stepOrder     Int?           @map("step_order")
  scheduledDate DateTime?      @db.Date @map("scheduled_date")
  scheduledTime String?        @map("scheduled_time")
  venue         String?
  score         Float?
  result        String?
  notes         String?
  conductedAt   DateTime?      @db.Timestamptz @map("conducted_at")
  createdAt     DateTime       @default(now()) @db.Timestamptz @map("created_at")
  
  applicant     Applicant      @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([applicantId], name: "idx_assessments_applicant_id")
  @@index([applicantId, type], name: "idx_assessments_applicant_type")
  @@map("applicant_assessments")
}

/// SCP-specific details, only present for Special Curricular Program applicants
model ApplicantProgramDetail {
  id              Int           @id @default(autoincrement())
  applicantId     Int           @unique(map: "uq_applicant_program_details_id") @map("applicant_id")
  scpType         ApplicantType @map("scp_type")
  artField        String?       @map("art_field")
  foreignLanguage String?       @map("foreign_language")
  sportsList      String[]      @map("sports_list")
  
  applicant       Applicant     @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@map("applicant_program_details")
}

/// Uploaded documentary requirements (PSA, SF9, etc.) attached to an applicant
model ApplicantDocument {
  id               Int            @id @default(autoincrement())
  applicantId      Int            @map("applicant_id")
  documentType     DocumentType   @map("document_type")
  status           DocumentStatus @default(SUBMITTED)
  fileName         String?        @map("file_name")
  originalName     String?        @map("original_name")
  mimeType         String?        @map("mime_type")
  size             Int?
  verificationNote String?        @map("verification_note")
  isPresentedOnly  Boolean        @default(false) @map("is_presented_only")
  uploadedAt       DateTime       @default(now()) @db.Timestamptz @map("uploaded_at")
  uploadedById     Int?           @map("uploaded_by_id")
  verifiedAt       DateTime?      @db.Timestamptz @map("verified_at")
  verifiedById     Int?           @map("verified_by_id")
  
  applicant        Applicant      @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  uploadedBy       User?          @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])
  verifiedBy       User?          @relation("DocumentVerifiedBy", fields: [verifiedById], references: [id])

  @@index([applicantId], name: "idx_documents_applicant_id")
  @@index([applicantId, documentType], name: "idx_documents_applicant_type")
  @@index([applicantId, status, documentType], name: "idx_documents_applicant_status_type")
  @@map("applicant_documents")
}

/// DepEd documentary requirement checklist per applicant (presented/collected flags)
model ApplicantChecklist {
  id                                 Int       @id @default(autoincrement())
  applicantId                        Int       @unique(map: "uq_applicant_checklists_id") @map("applicant_id")
  isPsaBirthCertPresented            Boolean   @default(false) @map("is_psa_birth_cert_presented")
  isOriginalPsaBcCollected           Boolean   @default(false) @map("is_original_psa_bc_collected")
  isSf9Submitted                     Boolean   @default(false) @map("is_sf9_submitted")
  isSf10Requested                    Boolean   @default(false) @map("is_sf10_requested")
  isGoodMoralPresented               Boolean   @default(false) @map("is_good_moral_presented")
  isMedicalEvalSubmitted             Boolean   @default(false) @map("is_medical_eval_submitted")
  isCertOfRecognitionPresented       Boolean   @default(false) @map("is_cert_of_recognition_presented")
  isUndertakingSigned                Boolean   @default(false) @map("is_undertaking_signed")
  isConfirmationSlipReceived         Boolean   @default(false) @map("is_confirmation_slip_received")
  updatedAt                          DateTime  @updatedAt @db.Timestamptz @map("updated_at")
  updatedById                        Int?      @map("updated_by_id")
  
  applicant                          Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  updatedBy                          User?     @relation(fields: [updatedById], references: [id])

  @@map("applicant_checklists")
}

/// Final enrollment record linking an approved applicant to a section in a school year
model Enrollment {
  id             Int          @id @default(autoincrement())
  applicantId    Int          @unique(map: "uq_enrollments_applicant_id") @map("applicant_id")
  sectionId      Int          @map("section_id")
  schoolYearId   Int          @map("school_year_id")
  enrolledAt     DateTime     @default(now()) @db.Timestamptz @map("enrolled_at")
  enrolledById   Int          @map("enrolled_by_id")
  
  schoolYear     SchoolYear   @relation(fields: [schoolYearId], references: [id])
  applicant      Applicant    @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  enrolledBy     User         @relation(fields: [enrolledById], references: [id])
  section        Section      @relation(fields: [sectionId], references: [id])

  @@index([sectionId], name: "idx_enrollments_section_id")
  @@index([schoolYearId], name: "idx_enrollments_school_year_id")
  @@index([enrolledById], name: "idx_enrollments_enrolled_by_id")
  @@map("enrollments")
}

/// Academic department (future use)
model Department {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique(map: "uq_departments_code")
  description String?
  createdAt   DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz @map("updated_at")

  @@map("departments")
}

/// Immutable audit trail of all system actions with actor, IP, and user-agent
model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  actionType  String   @map("action_type")
  description String
  subjectType String?  @map("subject_type")
  recordId    Int?     @map("record_id")
  ipAddress   String   @db.VarChar(45) @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @db.Timestamptz @map("created_at")
  
  user        User?    @relation(fields: [userId], references: [id])

  @@index([actionType], name: "idx_audit_logs_action_type")
  @@index([createdAt], name: "idx_audit_logs_created_at")
  @@index([userId], name: "idx_audit_logs_user_id")
  @@index([userId, createdAt], name: "idx_audit_logs_user_created")
  @@map("audit_logs")
}

/// Transactional email log tracking delivery status to applicant email addresses
model EmailLog {
  id           Int          @id @default(autoincrement())
  recipient    String
  subject      String
  trigger      EmailTrigger
  status       EmailStatus  @default(PENDING)
  applicantId  Int?         @map("applicant_id")
  errorMessage String?      @map("error_message")
  attemptedAt  DateTime     @default(now()) @db.Timestamptz @map("attempted_at")
  sentAt       DateTime?    @db.Timestamptz @map("sent_at")
  
  applicant    Applicant?   @relation(fields: [applicantId], references: [id])

  @@index([status], name: "idx_email_logs_status")
  @@index([trigger], name: "idx_email_logs_trigger")
  @@map("email_logs")
}

/// Student health measurement (SF8): weight, height per assessment period (BOSY/EOSY)
model HealthRecord {
  id               Int              @id @default(autoincrement())
  applicantId      Int              @map("applicant_id")
  schoolYearId     Int              @map("school_year_id")
  assessmentPeriod AssessmentPeriod @map("assessment_period")
  assessmentDate   DateTime         @db.Date @map("assessment_date")
  weightKg         Float            @map("weight_kg")
  heightCm         Float            @map("height_cm")
  notes            String?
  recordedById     Int              @map("recorded_by_id")
  createdAt        DateTime         @default(now()) @db.Timestamptz @map("created_at")
  updatedAt        DateTime         @updatedAt @db.Timestamptz @map("updated_at")

  applicant  Applicant  @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  schoolYear SchoolYear @relation(fields: [schoolYearId], references: [id])
  recordedBy User       @relation("HealthRecordRecordedBy", fields: [recordedById], references: [id])

  @@unique([applicantId, schoolYearId, assessmentPeriod], name: "uq_health_records_period")
  @@index([applicantId], name: "idx_health_records_applicant_id")
  @@index([applicantId, schoolYearId], name: "idx_health_records_applicant_sy")
  @@index([recordedById], name: "idx_health_records_recorded_by_id")
  @@map("health_records")
}

/// Special Curricular Program configuration per school year and applicant type
model ScpProgramConfig {
  id                Int               @id @default(autoincrement())
  schoolYearId      Int               @map("school_year_id")
  scpType           ApplicantType     @map("scp_type")
  isOffered         Boolean           @default(false) @map("is_offered")
  isTwoPhase        Boolean           @default(false) @map("is_two_phase")
  cutoffScore       Float?            @map("cutoff_score")
  gradeRequirements Json?             @map("grade_requirements")
  rankingFormula    Json?             @map("ranking_formula")
  notes             String?

  schoolYear SchoolYear          @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  options    ScpProgramOption[]
  steps      ScpProgramStep[]

  @@unique([schoolYearId, scpType], name: "uq_scp_program_configs_type")
  @@map("scp_program_configs")
}

/// Ordered assessment step in an SCP admission pipeline
model ScpProgramStep {
  id            Int            @id @default(autoincrement())
  scpProgramConfigId Int            @map("scp_program_config_id")
  stepOrder          Int            @map("step_order")
  kind               AssessmentKind @map("assessment_kind")
  label              String
  description        String?
  isRequired         Boolean        @default(true) @map("is_required")
  scheduledDate      DateTime?      @db.Date @map("scheduled_date")
  scheduledTime      String?        @map("scheduled_time")
  venue              String?
  notes              String?
  cutoffScore        Float?         @map("cutoff_score")
  
  scpProgramConfig   ScpProgramConfig @relation(fields: [scpProgramConfigId], references: [id], onDelete: Cascade)

  @@unique([scpProgramConfigId, stepOrder], name: "uq_scp_program_steps_order")
  @@index([scpProgramConfigId], name: "idx_scp_program_steps_config_id")
  @@map("scp_program_steps")
}

/// Options for SCP configuration: art fields, languages, and sports per SCP config
model ScpProgramOption {
  id          Int           @id @default(autoincrement())
  scpProgramConfigId Int           @map("scp_program_config_id")
  optionType         ScpOptionType @map("option_type")
  value              String
  
  scpProgramConfig   ScpProgramConfig @relation(fields: [scpProgramConfigId], references: [id], onDelete: Cascade)

  @@unique([scpProgramConfigId, optionType, value], name: "uq_scp_program_options_value")
  @@index([scpProgramConfigId], name: "idx_scp_program_options_config_id")
  @@map("scp_program_options")
}

/// Teacher subject specializations
model TeacherSubject {
  id        Int     @id @default(autoincrement())
  teacherId Int     @map("teacher_id")
  subject   String
  
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subject], name: "uq_teacher_subjects_subject")
  @@index([teacherId], name: "idx_teacher_subjects_teacher_id")
  @@map("teacher_subjects")
}

// ═══════════════════════════════════════════════════════════
// DO 017 s.2025 — Basic Education Early Registration Module
// ═══════════════════════════════════════════════════════════

/// Learner demographics captured during early registration (Phase 1: Jan–May)
model EarlyRegistrant {
  id                      Int       @id @default(autoincrement())
  lrn                     String?   @db.VarChar(12)
  firstName               String    @map("first_name")
  lastName                String    @map("last_name")
  middleName              String?   @map("middle_name")
  extensionName           String?   @map("extension_name")
  birthdate               DateTime  @db.Date
  sex                     Sex
  religion                String?
  isIpCommunity           Boolean   @default(false) @map("is_ip_community")
  ipGroupName             String?   @map("ip_group_name")
  isLearnerWithDisability Boolean   @default(false) @map("is_learner_with_disability")
  disabilityTypes         String[]  @map("disability_types")
  houseNoStreet           String?   @map("house_no_street")
  sitio                   String?
  barangay                String
  cityMunicipality        String    @map("city_municipality")
  province                String
  createdAt               DateTime  @default(now()) @db.Timestamptz @map("created_at")
  updatedAt               DateTime  @updatedAt @db.Timestamptz @map("updated_at")

  guardians               EarlyRegistrantGuardian[]
  registrations           EarlyRegistration[]

  @@unique([lrn], map: "uq_early_registrants_lrn")
  @@index([lastName, firstName, birthdate], name: "idx_early_registrants_dedup")
  @@map("early_registrants")
}

/// Parent or guardian info attached to an early registrant
model EarlyRegistrantGuardian {
  id            Int    @id @default(autoincrement())
  registrantId  Int    @map("registrant_id")
  relationship  String /// FATHER | MOTHER | GUARDIAN
  lastName      String @map("last_name")
  firstName     String @map("first_name")
  middleName    String? @map("middle_name")
  contactNumber String? @map("contact_number")
  email         String?

  registrant    EarlyRegistrant @relation(fields: [registrantId], references: [id], onDelete: Cascade)

  @@index([registrantId], name: "idx_early_registrant_guardians_registrant_id")
  @@map("early_registrant_guardians")
}

/// One registration record per learner per school year (Phase 1 early reg)
model EarlyRegistration {
  id                   Int       @id @default(autoincrement())
  registrantId         Int       @map("registrant_id")
  schoolYearId         Int       @map("school_year_id")
  gradeLevel           String    @map("grade_level") /// 7 | 8 | 9 | 10
  learnerType          String    @map("learner_type") /// NEW_ENROLLEE | TRANSFEREE | etc.
  applicantType        ApplicantType @default(REGULAR) @map("applicant_type")
  status               String    @default("SUBMITTED") /// DRAFT | SUBMITTED | VERIFIED | LINKED
  channel              String    @default("ONLINE") /// ONLINE | F2F
  gradeLevelIdV2       Int?      @map("grade_level_id_v2")
  learnerTypeV2        LearnerType? @map("learner_type_v2")
  statusV2             EarlyRegistrationLifecycleStatus? @map("status_v2")
  channelV2            AdmissionChannel? @map("channel_v2")
  contactNumber        String    @map("contact_number")
  email                String?
  primaryContact       String?   @map("primary_contact") /// FATHER | MOTHER | GUARDIAN
  primaryContactV2     PrimaryContactType? @map("primary_contact_v2")
  hasNoMother          Boolean   @default(false) @map("has_no_mother")
  hasNoFather          Boolean   @default(false) @map("has_no_father")
  isPrivacyConsentGiven Boolean  @map("is_privacy_consent_given")
  applicantId          Int?      @map("applicant_id") /// set when linked to enrollment
  encodedById          Int?      @map("encoded_by_id") /// null for public submissions
  verifiedAt           DateTime? @db.Timestamptz @map("verified_at")
  verifiedById         Int?      @map("verified_by_id")
  submittedAt          DateTime  @default(now()) @db.Timestamptz @map("submitted_at")
  createdAt            DateTime  @default(now()) @db.Timestamptz @map("created_at")
  updatedAt            DateTime  @updatedAt @db.Timestamptz @map("updated_at")

  registrant           EarlyRegistrant @relation(fields: [registrantId], references: [id], onDelete: Cascade)
  schoolYear           SchoolYear      @relation(fields: [schoolYearId], references: [id])
  gradeLevelV2         GradeLevel?     @relation(fields: [gradeLevelIdV2], references: [id])
  applicant            Applicant?      @relation(fields: [applicantId], references: [id])
  encodedBy            User?           @relation("EarlyRegEncodedBy", fields: [encodedById], references: [id])
  verifiedBy           User?           @relation("EarlyRegVerifiedBy", fields: [verifiedById], references: [id])

  @@unique([registrantId, schoolYearId], name: "uq_early_registrations_per_sy")
  @@index([schoolYearId, status], name: "idx_early_registrations_sy_status")
  @@index([schoolYearId, applicantType, status], name: "idx_early_registrations_sy_type_status")
  @@index([schoolYearId, statusV2], name: "idx_early_registrations_sy_status_v2")
  @@index([applicantId], name: "idx_early_registrations_applicant_id")
  @@index([gradeLevelIdV2], name: "idx_early_registrations_grade_level_v2")
  @@map("early_registrations")
}

/// User role: REGISTRAR handles enrollment; SYSTEM_ADMIN has full access
enum Role {
  REGISTRAR
  SYSTEM_ADMIN
  TEACHER

  @@map("user_role")
}

/// Documentary compliance status for temporarily enrolled learners
enum ComplianceStatus {
  PENDING
  COMPLIED
  OVERDUE

  @@map("compliance_status")
}

/// Typed lifecycle for staged EarlyRegistration migration
enum EarlyRegistrationLifecycleStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  LINKED

  @@map("early_registration_lifecycle_status")
}

/// Primary contact selector for guardian communications
enum PrimaryContactType {
  FATHER
  MOTHER
  GUARDIAN

  @@map("primary_contact_type")
}

/// Biological sex per DepEd SF1
enum Sex {
  MALE
  FEMALE

  @@map("sex")
}

/// Admission pipeline stages from initial submission through final enrollment
enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  FOR_REVISION
  ELIGIBLE
  ASSESSMENT_SCHEDULED
  ASSESSMENT_TAKEN
  PASSED
  INTERVIEW_SCHEDULED
  PRE_REGISTERED
  TEMPORARILY_ENROLLED
  NOT_QUALIFIED
  ENROLLED
  REJECTED
  WITHDRAWN

  @@map("application_status")
}

/// School year lifecycle: DRAFT (config) → UPCOMING (visible) → ACTIVE (current) → ARCHIVED
enum SchoolYearStatus {
  DRAFT
  UPCOMING
  ACTIVE
  ARCHIVED

  @@map("school_year_status")
}

/// Enrollment classification: REGULAR standard admission, Special Curricular Programs
enum ApplicantType {
  REGULAR
  SCIENCE_TECHNOLOGY_AND_ENGINEERING
  SPECIAL_PROGRAM_IN_THE_ARTS
  SPECIAL_PROGRAM_IN_SPORTS
  SPECIAL_PROGRAM_IN_JOURNALISM
  SPECIAL_PROGRAM_IN_FOREIGN_LANGUAGE
  SPECIAL_PROGRAM_IN_TECHNICAL_VOCATIONAL_EDUCATION

  @@map("applicant_type")
}

/// Events that trigger automated email notifications
enum EmailTrigger {
  APPLICATION_SUBMITTED
  APPLICATION_APPROVED
  APPLICATION_REJECTED
  EXAM_SCHEDULED
  ASSESSMENT_PASSED
  ASSESSMENT_FAILED

  @@map("email_trigger")
}

/// Email delivery status
enum EmailStatus {
  PENDING
  SENT
  FAILED

  @@map("email_status")
}

/// How the application was submitted: ONLINE (self-service) or F2F (registrar-encoded)
enum AdmissionChannel {
  ONLINE
  F2F

  @@map("admission_channel")
}

/// Document verification status in the requirement checklist
enum DocumentStatus {
  SUBMITTED
  VERIFIED
  REJECTED
  MISSING

  @@map("document_status")
}

/// DepEd documentary requirement types per enrollment policy
enum DocumentType {
  PSA_BIRTH_CERTIFICATE
  SECONDARY_BIRTH_PROOF
  SF9_REPORT_CARD
  SF10_PERMANENT_RECORD
  GOOD_MORAL_CERTIFICATE
  MEDICAL_CERTIFICATE
  CERTIFICATE_OF_RECOGNITION
  MEDICAL_EVALUATION
  PEPT_AE_CERTIFICATE
  PWD_ID
  PSA_MARRIAGE_CERTIFICATE
  UNDERTAKING
  AFFIDAVIT_OF_UNDERTAKING
  CONFIRMATION_SLIP
  OTHERS

  @@map("document_type")
}

/// Student enrollment type classification
enum LearnerType {
  NEW_ENROLLEE
  TRANSFEREE
  RETURNING
  CONTINUING
  OSCYA
  ALS

  @@map("learner_type")
}

/// Health record assessment period: Beginning of School Year or End of School Year
enum AssessmentPeriod {
  BOSY
  EOSY

  @@map("assessment_period")
}

/// Address type: current residential or permanent
enum AddressType {
  CURRENT
  PERMANENT

  @@map("address_type")
}

/// Family member relationship to the applicant
enum FamilyRelationship {
  MOTHER
  FATHER
  GUARDIAN

  @@map("family_relationship")
}

/// DepEd SCP assessment types per program admission pipeline
enum AssessmentKind {
  INTERVIEW
  QUALIFYING_EXAMINATION
  PRELIMINARY_EXAMINATION
  FINAL_EXAMINATION
  GENERAL_ADMISSION_TEST
  TALENT_AUDITION
  PHYSICAL_FITNESS_TEST
  SPORTS_SKILLS_TRYOUT
  SKILLS_ASSESSMENT
  STANDARDIZED_ADMISSION_TOOL
  APTITUDE_TEST
  INTEREST_INVENTORY

  @@map("assessment_kind")
}

/// SCP configuration option category
enum ScpOptionType {
  ART_FIELD
  LANGUAGE
  SPORT

  @@map("scp_option_type")
}
