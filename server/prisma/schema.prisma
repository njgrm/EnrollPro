generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows"]
  output = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// System users: registrars and system administrators who manage the enrollment process
model User {
  id                 Int          @id @default(autoincrement())
  firstName          String       @map("first_name")
  lastName           String       @map("last_name")
  middleName         String?      @map("middle_name")
  suffix             String?
  sex                Sex          @default(FEMALE)
  employeeId         String?      @unique(map: "uq_users_employee_id") @map("employee_id")
  designation        String?
  mobileNumber       String?      @map("mobile_number")
  email              String       @unique(map: "uq_users_email")
  password           String
  role               Role
  isActive           Boolean      @default(true) @map("is_active")
  lastLoginAt        DateTime?    @db.Timestamptz @map("last_login_at")
  mustChangePassword Boolean      @default(false) @map("must_change_password")
  createdById        Int?         @map("created_by_id")
  createdAt          DateTime     @default(now()) @db.Timestamptz @map("created_at")
  updatedAt          DateTime     @updatedAt @db.Timestamptz @map("updated_at")
  
  auditLogs          AuditLog[]
  createdBy          User?        @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers       User[]       @relation("UserCreatedBy")
  
  // Relations to Early Registration
  encodedEarlyRegs   EarlyRegistrationApplication[] @relation("EarlyRegEncodedBy")
  verifiedEarlyRegs  EarlyRegistrationApplication[] @relation("EarlyRegVerifiedBy")
  
  // Unified Application Relations
  updatedChecklists  ApplicationChecklist[] @relation("ChecklistUpdatedBy")
  updatedTeacherDesignations TeacherDesignation[] @relation("TeacherDesignationUpdatedBy")

  // Relations to Enrollment
  encodedEnrollmentApps EnrollmentApplication[] @relation("EnrollmentAppEncodedBy")
  profileLockedEnrollmentApps EnrollmentApplication[] @relation("EnrollmentProfileLockedBy")
  enrollmentRecords      EnrollmentRecord[]
  
  recordedHealthRecords HealthRecord[] @relation("HealthRecordRecordedBy")

  @@map("users")
}

/// Faculty members who serve as section advisers; not login users
model Teacher {
  id             Int       @id @default(autoincrement())
  employeeId     String?   @unique(map: "uq_teachers_employee_id") @map("employee_id")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  middleName     String?   @map("middle_name")
  email          String?   @map("email")
  contactNumber  String?   @map("contact_number")
  specialization String?
  photoPath      String?   @map("photo_path")
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @db.Timestamptz @map("created_at")
  updatedAt      DateTime         @updatedAt @db.Timestamptz @map("updated_at")
  
  sections       Section[]
  subjects       TeacherSubject[]
  teacherDesignations TeacherDesignation[]
  atlasSyncEvents AtlasSyncEvent[]

  @@map("teachers")
}

/// Singleton config: school identity (name, logo, accent color) and active school year pointer
model SchoolSetting {
  id                   Int           @id @default(autoincrement())
  schoolName           String        @map("school_name")
  logoPath             String?       @map("logo_path")
  logoUrl              String?       @map("logo_url")
  colorScheme          Json?         @map("color_scheme")
  selectedAccentHsl    String?       @map("selected_accent_hsl")
  activeSchoolYearId   Int?          @map("active_school_year_id")
  
  activeSchoolYear     SchoolYear?   @relation(fields: [activeSchoolYearId], references: [id])

  @@map("school_settings")
}

/// Academic year with enrollment window dates and lifecycle status
model SchoolYear {
  id                 Int              @id @default(autoincrement())
  yearLabel          String           @unique(map: "uq_school_years_year_label") @map("year_label")
  status             SchoolYearStatus @default(DRAFT)
  classOpeningDate   DateTime?        @db.Date @map("class_opening_date")
  classEndDate       DateTime?        @db.Date @map("class_end_date")
  earlyRegOpenDate   DateTime?        @db.Date @map("early_reg_open_date")
  earlyRegCloseDate  DateTime?        @db.Date @map("early_reg_close_date")
  enrollOpenDate     DateTime?        @db.Date @map("enroll_open_date")
  enrollCloseDate    DateTime?        @db.Date @map("enroll_close_date")
  isManualOverrideOpen Boolean        @default(false) @map("is_manual_override_open")
  clonedFromId       Int?             @map("cloned_from_id")
  createdAt          DateTime         @default(now()) @db.Timestamptz @map("created_at")
  
  clonedFrom         SchoolYear?      @relation("SchoolYearClone", fields: [clonedFromId], references: [id])
  clones             SchoolYear[]     @relation("SchoolYearClone")
  gradeLevels        GradeLevel[]
  schoolSettings     SchoolSetting[]
  scpProgramConfigs  ScpProgramConfig[]
  healthRecords      HealthRecord[]
  teacherDesignations TeacherDesignation[]
  atlasSyncEvents      AtlasSyncEvent[]
  
  earlyRegistrationApplications EarlyRegistrationApplication[]
  enrollmentApplications        EnrollmentApplication[]
  enrollmentRecords             EnrollmentRecord[]

  @@map("school_years")
}

/// JHS grade levels (e.g. Grade 7, Grade 10) cloned per school year
model GradeLevel {
  id             Int          @id @default(autoincrement())
  name           String
  displayOrder   Int          @map("display_order")
  schoolYearId   Int          @map("school_year_id")
  createdAt      DateTime     @default(now()) @db.Timestamptz @map("created_at")
  
  schoolYear     SchoolYear   @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  sections       Section[]
  
  earlyRegistrationApplications EarlyRegistrationApplication[]
  enrollmentApplications        EnrollmentApplication[]

  @@index([schoolYearId], name: "idx_grade_levels_school_year_id")
  @@map("grade_levels")
}

/// Class section with capacity, grade level, and optional advising teacher
model Section {
  id                Int          @id @default(autoincrement())
  name              String
  maxCapacity       Int          @default(40) @map("max_capacity")
  gradeLevelId      Int          @map("grade_level_id")
  programType       ApplicantType @default(REGULAR) @map("program_type")
  advisingTeacherId Int?         @map("advising_teacher_id")
  createdAt         DateTime     @default(now()) @db.Timestamptz @map("created_at")
  updatedAt         DateTime     @updatedAt @db.Timestamptz @map("updated_at")
  
  advisingTeacher   Teacher?     @relation(fields: [advisingTeacherId], references: [id])
  gradeLevel        GradeLevel   @relation(fields: [gradeLevelId], references: [id], onDelete: Cascade)
  enrollmentRecords EnrollmentRecord[]
  teacherDesignations TeacherDesignation[] @relation("TeacherDesignationAdvisorySection")

  @@index([gradeLevelId], name: "idx_sections_grade_level_id")
  @@index([gradeLevelId, programType], name: "idx_sections_grade_level_program_type")
  @@map("sections")
}

// ═══════════════════════════════════════════════════════════
// CENTRALIZED LEARNER IDENTITY
// ═══════════════════════════════════════════════════════════

/// Core learner demographics shared between early registration and enrollment
model Learner {
  id                      Int       @id @default(autoincrement())
  lrn                     String?   @unique(map: "uq_learners_lrn") @db.VarChar(12)
  isPendingLrnCreation    Boolean   @default(false) @map("is_pending_lrn_creation")
  psaBirthCertNumber      String?   @map("psa_birth_cert_number")
  firstName               String    @map("first_name")
  lastName                String    @map("last_name")
  middleName              String?   @map("middle_name")
  extensionName           String?   @map("extension_name")
  birthdate               DateTime  @db.Date
  sex                     Sex
  placeOfBirth            String?   @map("place_of_birth")
  religion                String?
  motherTongue            String?   @map("mother_tongue")
  isIpCommunity           Boolean   @default(false) @map("is_ip_community")
  ipGroupName             String?   @map("ip_group_name")
  isLearnerWithDisability Boolean   @default(false) @map("is_learner_with_disability")
  disabilityTypes         String[]  @map("disability_types")
  specialNeedsCategory    String?   @map("special_needs_category")
  hasPwdId                Boolean   @default(false) @map("has_pwd_id")
  is4PsBeneficiary        Boolean   @default(false) @map("is_4ps_beneficiary")
  householdId4Ps          String?   @map("household_id_4ps")
  isBalikAral             Boolean   @default(false) @map("is_balik_aral")
  lastYearEnrolled        String?   @map("last_year_enrolled")
  lastGradeLevel          String?   @map("last_grade_level")
  createdAt               DateTime  @default(now()) @db.Timestamptz @map("created_at")
  updatedAt               DateTime  @updatedAt @db.Timestamptz @map("updated_at")

  earlyRegistrationApplications EarlyRegistrationApplication[]
  enrollmentApplications        EnrollmentApplication[]
  healthRecords                 HealthRecord[]

  @@index([lastName, firstName, birthdate], name: "idx_learners_dedup")
  @@map("learners")
}

// ═══════════════════════════════════════════════════════════
// PHASE 1: EARLY REGISTRATION PROCESS (/early-registration)
// ═══════════════════════════════════════════════════════════

/// One registration record per learner per school year (Phase 1: Jan–May)
model EarlyRegistrationApplication {
  id                    Int       @id @default(autoincrement())
  learnerId             Int       @map("learner_id")
  schoolYearId          Int       @map("school_year_id")
  gradeLevelId          Int       @map("grade_level_id")
  trackingNumber        String    @unique(map: "uq_early_reg_tracking_number") @map("tracking_number")
  applicantType         ApplicantType @default(REGULAR) @map("applicant_type")
  learnerType           LearnerType   @default(NEW_ENROLLEE) @map("learner_type")
  status                ApplicationStatus @default(SUBMITTED)
  channel               AdmissionChannel  @default(ONLINE)
  contactNumber         String    @map("contact_number")
  studentPhoto          String?   @map("student_photo")
  email                 String?
  primaryContact        PrimaryContactType? @map("primary_contact")
  guardianRelationship  String?   @map("guardian_relationship")
  hasNoMother           Boolean   @default(false) @map("has_no_mother")
  hasNoFather           Boolean   @default(false) @map("has_no_father")
  isPrivacyConsentGiven Boolean   @map("is_privacy_consent_given")
  encodedById           Int?      @map("encoded_by_id")
  verifiedAt            DateTime? @db.Timestamptz @map("verified_at")
  verifiedById          Int?      @map("verified_by_id")
  submittedAt           DateTime  @default(now()) @db.Timestamptz @map("submitted_at")
  createdAt             DateTime  @default(now()) @db.Timestamptz @map("created_at")
  updatedAt             DateTime  @updatedAt @db.Timestamptz @map("updated_at")

  learner               Learner    @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  schoolYear            SchoolYear @relation(fields: [schoolYearId], references: [id])
  gradeLevel            GradeLevel @relation(fields: [gradeLevelId], references: [id])
  encodedBy             User?      @relation("EarlyRegEncodedBy", fields: [encodedById], references: [id])
  verifiedBy            User?      @relation("EarlyRegVerifiedBy", fields: [verifiedById], references: [id])
  
  familyMembers         ApplicationFamilyMember[]
  assessments           EarlyRegistrationAssessment[]
  addresses             ApplicationAddress[]
  checklist             ApplicationChecklist?
  enrollmentApplications EnrollmentApplication[]

  @@unique([learnerId, schoolYearId], name: "uq_early_reg_per_sy")
  @@index([schoolYearId, status], name: "idx_early_reg_sy_status")
  @@index([trackingNumber], name: "idx_early_reg_tracking_no")
  @@map("early_registration_applications")
}

/// Screening assessments taken during early registration (e.g., STE Qualifying Exam)
model EarlyRegistrationAssessment {
  id            Int            @id @default(autoincrement())
  applicationId Int            @map("application_id")
  type          AssessmentKind @map("assessment_kind")
  scheduledDate DateTime?      @db.Date @map("scheduled_date")
  scheduledTime String?        @map("scheduled_time")
  venue         String?
  score         Float?
  result        String?
  notes         String?
  conductedAt   DateTime?      @db.Timestamptz @map("conducted_at")
  createdAt     DateTime       @default(now()) @db.Timestamptz @map("created_at")
  
  application   EarlyRegistrationApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId], name: "idx_early_reg_assessments_app_id")
  @@map("early_registration_assessments")
}

// ═══════════════════════════════════════════════════════════
// PHASE 2: ENROLLMENT PROCESS (/enrollment)
// ═══════════════════════════════════════════════════════════

/// The Basic Education Enrollment Form record
model EnrollmentApplication {
  id                      Int               @id @default(autoincrement())
  learnerId               Int               @map("learner_id")
  earlyRegistrationId     Int?              @map("early_registration_id")
  schoolYearId            Int               @map("school_year_id")
  gradeLevelId            Int               @map("grade_level_id")
  applicantType           ApplicantType     @default(REGULAR) @map("applicant_type")
  learnerType             LearnerType       @default(NEW_ENROLLEE) @map("learner_type")
  status                  ApplicationStatus @default(SUBMITTED)
  admissionChannel        AdmissionChannel  @default(ONLINE) @map("admission_channel")
  trackingNumber          String?           @unique(map: "uq_enrollment_tracking_number") @map("tracking_number")
  studentPhoto            String?           @map("student_photo")
  learningModalities      String[]          @map("learning_modalities")
  isTemporarilyEnrolled   Boolean           @default(false) @map("is_temporarily_enrolled")
  documentaryDeadlineAt   DateTime?         @db.Date @map("documentary_deadline_at")
  complianceStatus        ComplianceStatus? @map("compliance_status")
  rejectionReason         String?           @map("rejection_reason")
  isPrivacyConsentGiven   Boolean           @default(false) @map("is_privacy_consent_given")
  guardianRelationship    String?           @map("guardian_relationship")
  hasNoMother             Boolean           @default(false) @map("has_no_mother")
  hasNoFather             Boolean           @default(false) @map("has_no_father")
  portalPin               String?           @map("portal_pin")
  portalPinChangedAt      DateTime?         @db.Timestamptz @map("portal_pin_changed_at")
  isProfileLocked         Boolean           @default(false) @map("is_profile_locked")
  profileLockedAt         DateTime?         @db.Timestamptz @map("profile_locked_at")
  profileLockedById       Int?              @map("profile_locked_by_id")
  encodedById             Int?              @map("encoded_by_id")
  createdAt               DateTime          @default(now()) @db.Timestamptz @map("created_at")
  updatedAt               DateTime          @updatedAt @db.Timestamptz @map("updated_at")
  
  learner                 Learner           @relation(fields: [learnerId], references: [id])
  earlyRegistration       EarlyRegistrationApplication? @relation(fields: [earlyRegistrationId], references: [id])
  schoolYear              SchoolYear        @relation(fields: [schoolYearId], references: [id])
  gradeLevel              GradeLevel        @relation(fields: [gradeLevelId], references: [id])
  encodedBy               User?             @relation("EnrollmentAppEncodedBy", fields: [encodedById], references: [id])
  profileLockedBy         User?             @relation("EnrollmentProfileLockedBy", fields: [profileLockedById], references: [id])
  
  addresses               ApplicationAddress[]
  familyMembers           ApplicationFamilyMember[]
  previousSchool          EnrollmentPreviousSchool?
  programDetail           EnrollmentProgramDetail?
  checklist               ApplicationChecklist?
  emailLogs               EmailLog[]
  enrollmentRecord        EnrollmentRecord?

  @@index([status, schoolYearId], name: "idx_enrollment_apps_status_sy")
  @@map("enrollment_applications")
}

/// Previous school record linked to enrollment application
model EnrollmentPreviousSchool {
  id                  Int       @id @default(autoincrement())
  applicationId       Int       @unique(map: "uq_enrollment_prev_school_app_id") @map("application_id")
  schoolName          String?   @map("school_name")
  schoolDepedId       String?   @map("school_deped_id")
  gradeCompleted      String?   @map("grade_completed")
  schoolYearAttended  String?   @map("school_year_attended")
  schoolAddress       String?   @map("school_address")
  schoolType          String?   @map("school_type")
  natScore            Float?    @map("nat_score")
  generalAverage      Float?    @map("general_average")
  
  application         EnrollmentApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("enrollment_previous_schools")
}

/// SCP-specific details for enrollment applications
model EnrollmentProgramDetail {
  id              Int           @id @default(autoincrement())
  applicationId   Int           @unique(map: "uq_enrollment_prog_detail_app_id") @map("application_id")
  scpType         ApplicantType @map("scp_type")
  artField        String?       @map("art_field")
  foreignLanguage String?       @map("foreign_language")
  sportsList      String[]      @map("sports_list")
  
  application     EnrollmentApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("enrollment_program_details")
}

/// Address linked to an application (Early Reg or Enrollment)
model ApplicationAddress {
  id               Int         @id @default(autoincrement())
  earlyRegistrationId Int?      @map("early_registration_id")
  enrollmentId     Int?        @map("enrollment_id")
  addressType      AddressType @map("address_type")
  houseNoStreet    String?     @map("house_no")
  street           String?
  sitio            String?
  barangay         String?
  cityMunicipality String?     @map("city_municipality")
  province         String?
  country          String?     @default("PHILIPPINES")
  zipCode          String?     @map("zip_code")
  
  earlyRegistration EarlyRegistrationApplication? @relation(fields: [earlyRegistrationId], references: [id], onDelete: Cascade)
  enrollment        EnrollmentApplication?        @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([earlyRegistrationId, addressType], name: "uq_early_reg_addresses_type")
  @@unique([enrollmentId, addressType], name: "uq_enrollment_addresses_type")
  @@map("application_addresses")
}

/// Parent or guardian info linked to an application
model ApplicationFamilyMember {
  id               Int                @id @default(autoincrement())
  earlyRegistrationId Int?            @map("early_registration_id")
  enrollmentId     Int?               @map("enrollment_id")
  relationship     FamilyRelationship
  firstName        String             @map("first_name")
  lastName         String             @map("last_name")
  middleName       String?            @map("middle_name")
  contactNumber    String?            @map("contact_number")
  email            String?
  occupation       String?
  
  earlyRegistration EarlyRegistrationApplication? @relation(fields: [earlyRegistrationId], references: [id], onDelete: Cascade)
  enrollment        EnrollmentApplication?        @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, relationship], name: "uq_enrollment_family_members_rel")
  @@index([earlyRegistrationId], name: "idx_early_reg_guardians_app_id")
  @@map("application_family_members")
}

/// Requirement checklist per application
model ApplicationChecklist {
  id                                 Int       @id @default(autoincrement())
  earlyRegistrationId                Int?      @unique(map: "uq_early_reg_checklist_id") @map("early_registration_id")
  enrollmentId                       Int?      @unique(map: "uq_enrollment_checklist_id") @map("enrollment_id")
  academicStatus                     AcademicStatus @default(PROMOTED) @map("academic_status")
  isPsaBirthCertPresented            Boolean   @default(false) @map("is_psa_birth_cert_presented")
  isOriginalPsaBcCollected           Boolean   @default(false) @map("is_original_psa_bc_collected")
  isSf9Submitted                     Boolean   @default(false) @map("is_sf9_submitted")
  isSf10Requested                    Boolean   @default(false) @map("is_sf10_requested")
  isGoodMoralPresented               Boolean   @default(false) @map("is_good_moral_presented")
  isMedicalEvalSubmitted             Boolean   @default(false) @map("is_medical_eval_submitted")
  isCertOfRecognitionPresented       Boolean   @default(false) @map("is_cert_of_recognition_presented")
  isUndertakingSigned                Boolean   @default(false) @map("is_undertaking_signed")
  isConfirmationSlipReceived         Boolean   @default(false) @map("is_confirmation_slip_received")
  updatedAt                          DateTime  @updatedAt @db.Timestamptz @map("updated_at")
  updatedById                        Int?      @map("updated_by_id")
  
  earlyRegistration                  EarlyRegistrationApplication? @relation(fields: [earlyRegistrationId], references: [id], onDelete: Cascade)
  enrollment                         EnrollmentApplication?        @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  updatedBy                          User?     @relation("ChecklistUpdatedBy", fields: [updatedById], references: [id])

  @@map("application_checklists")
}

/// Final enrollment record linking an approved enrollment application to a section
model EnrollmentRecord {
  id                    Int          @id @default(autoincrement())
  enrollmentApplicationId Int        @unique(map: "uq_enroll_record_app_id") @map("enrollment_application_id")
  sectionId             Int          @map("section_id")
  schoolYearId          Int          @map("school_year_id")
  enrolledAt            DateTime     @default(now()) @db.Timestamptz @map("enrolled_at")
  enrolledById          Int          @map("enrolled_by_id")
  
  schoolYear            SchoolYear   @relation(fields: [schoolYearId], references: [id])
  enrollmentApplication EnrollmentApplication @relation(fields: [enrollmentApplicationId], references: [id], onDelete: Cascade)
  enrolledBy            User         @relation(fields: [enrolledById], references: [id])
  section               Section      @relation(fields: [sectionId], references: [id])

  @@index([sectionId], name: "idx_enroll_records_section_id")
  @@map("enrollment_records")
}

// ═══════════════════════════════════════════════════════════
// OTHER SYSTEM MODELS
// ═══════════════════════════════════════════════════════════

/// Academic department (future use)
model Department {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique(map: "uq_departments_code")
  description String?
  createdAt   DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz @map("updated_at")

  @@map("departments")
}

/// Immutable audit trail of all system actions
model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  actionType  String   @map("action_type")
  description String
  subjectType String?  @map("subject_type")
  recordId    Int?     @map("record_id")
  ipAddress   String   @db.VarChar(45) @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @db.Timestamptz @map("created_at")
  
  user        User?    @relation(fields: [userId], references: [id])

  @@index([actionType], name: "idx_audit_logs_action_type")
  @@index([createdAt], name: "idx_audit_logs_created_at")
  @@index([userId], name: "idx_audit_logs_user_id")
  @@map("audit_logs")
}

/// Transactional email log
model EmailLog {
  id           Int          @id @default(autoincrement())
  recipient    String
  subject      String
  trigger      EmailTrigger
  status       EmailStatus  @default(PENDING)
  applicationId Int?         @map("application_id")
  errorMessage String?      @map("error_message")
  attemptedAt  DateTime     @default(now()) @db.Timestamptz @map("attempted_at")
  sentAt       DateTime?    @db.Timestamptz @map("sent_at")
  
  application  EnrollmentApplication? @relation(fields: [applicationId], references: [id])

  @@index([status], name: "idx_email_logs_status")
  @@index([trigger], name: "idx_email_logs_trigger")
  @@map("email_logs")
}

/// Student health measurement (SF8)
model HealthRecord {
  id               Int              @id @default(autoincrement())
  learnerId        Int              @map("learner_id")
  schoolYearId     Int              @map("school_year_id")
  assessmentPeriod AssessmentPeriod @map("assessment_period")
  assessmentDate   DateTime         @db.Date @map("assessment_date")
  weightKg         Float            @map("weight_kg")
  heightCm         Float            @map("height_cm")
  notes            String?
  recordedById     Int              @map("recorded_by_id")
  createdAt        DateTime         @default(now()) @db.Timestamptz @map("created_at")
  updatedAt        DateTime         @updatedAt @db.Timestamptz @map("updated_at")

  learner    Learner    @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  schoolYear SchoolYear @relation(fields: [schoolYearId], references: [id])
  recordedBy User       @relation("HealthRecordRecordedBy", fields: [recordedById], references: [id])

  @@unique([learnerId, schoolYearId, assessmentPeriod], name: "uq_health_records_period")
  @@index([learnerId], name: "idx_health_records_learner_id")
  @@map("health_records")
}

/// Special Curricular Program configuration
model ScpProgramConfig {
  id                Int               @id @default(autoincrement())
  schoolYearId      Int               @map("school_year_id")
  scpType           ApplicantType     @map("scp_type")
  isOffered         Boolean           @default(false) @map("is_offered")
  isTwoPhase        Boolean           @default(false) @map("is_two_phase")
  cutoffScore       Float?            @map("cutoff_score")
  gradeRequirements Json?             @map("grade_requirements")
  rankingFormula    Json?             @map("ranking_formula")
  notes             String?

  schoolYear SchoolYear          @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  options    ScpProgramOption[]
  steps      ScpProgramStep[]

  @@unique([schoolYearId, scpType], name: "uq_scp_program_configs_type")
  @@map("scp_program_configs")
}

/// Ordered assessment step in an SCP admission pipeline
model ScpProgramStep {
  id            Int            @id @default(autoincrement())
  scpProgramConfigId Int            @map("scp_program_config_id")
  stepOrder          Int            @map("step_order")
  kind               AssessmentKind @map("assessment_kind")
  label              String
  description        String?
  isRequired         Boolean        @default(true) @map("is_required")
  scheduledDate      DateTime?      @db.Date @map("scheduled_date")
  scheduledTime      String?        @map("scheduled_time")
  venue         String?
  notes         String?
  cutoffScore   Float?         @map("cutoff_score")
  
  scpProgramConfig   ScpProgramConfig @relation(fields: [scpProgramConfigId], references: [id], onDelete: Cascade)

  @@unique([scpProgramConfigId, stepOrder], name: "uq_scp_program_steps_order")
  @@index([scpProgramConfigId], name: "idx_scp_program_steps_config_id")
  @@map("scp_program_steps")
}

/// Options for SCP configuration
model ScpProgramOption {
  id          Int           @id @default(autoincrement())
  scpProgramConfigId Int           @map("scp_program_config_id")
  optionType         ScpOptionType @map("option_type")
  value              String
  
  scpProgramConfig   ScpProgramConfig @relation(fields: [scpProgramConfigId], references: [id], onDelete: Cascade)

  @@unique([scpProgramConfigId, optionType, value], name: "uq_scp_program_options_value")
  @@index([scpProgramConfigId], name: "idx_scp_program_options_config_id")
  @@map("scp_program_options")
}

/// Teacher subject specializations
model TeacherSubject {
  id        Int     @id @default(autoincrement())
  teacherId Int     @map("teacher_id")
  subject   String
  
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subject], name: "uq_teacher_subjects_subject")
  @@index([teacherId], name: "idx_teacher_subjects_teacher_id")
  @@map("teacher_subjects")
}

/// School-year scoped ATLAS designation metadata for faculty load computation
model TeacherDesignation {
  id                               Int       @id @default(autoincrement())
  teacherId                        Int       @map("teacher_id")
  schoolYearId                     Int       @map("school_year_id")
  advisorySectionId                Int?      @map("advisory_section_id")
  isClassAdviser                   Boolean   @default(false) @map("is_class_adviser")
  advisoryEquivalentHoursPerWeek   Float     @default(0) @map("advisory_equivalent_hours_per_week")
  isTic                            Boolean   @default(false) @map("is_tic")
  isTeachingExempt                 Boolean   @default(false) @map("is_teaching_exempt")
  customTargetTeachingHoursPerWeek Float?    @map("custom_target_teaching_hours_per_week")
  designationNotes                 String?   @map("designation_notes")
  effectiveFrom                    DateTime? @db.Date @map("effective_from")
  effectiveTo                      DateTime? @db.Date @map("effective_to")
  updateReason                     String?   @map("update_reason")
  updatedById                      Int?      @map("updated_by_id")
  createdAt                        DateTime  @default(now()) @db.Timestamptz @map("created_at")
  updatedAt                        DateTime  @updatedAt @db.Timestamptz @map("updated_at")

  teacher                          Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  schoolYear                       SchoolYear @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  advisorySection                  Section?  @relation("TeacherDesignationAdvisorySection", fields: [advisorySectionId], references: [id], onDelete: SetNull)
  updatedBy                        User?     @relation("TeacherDesignationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([teacherId, schoolYearId], name: "uq_teacher_designations_teacher_sy")
  @@index([schoolYearId], name: "idx_teacher_designations_school_year_id")
  @@index([advisorySectionId], name: "idx_teacher_designations_advisory_section_id")
  @@index([updatedById], name: "idx_teacher_designations_updated_by_id")
  @@map("teacher_designations")
}

/// Outbound EnrollPro -> ATLAS synchronization events for observability and retries
model AtlasSyncEvent {
  id            Int             @id @default(autoincrement())
  eventId       String          @unique(map: "uq_atlas_sync_events_event_id") @map("event_id")
  eventType     String          @map("event_type")
  teacherId     Int?            @map("teacher_id")
  schoolYearId  Int?            @map("school_year_id")
  payload       Json
  requestUrl    String          @map("request_url")
  status        AtlasSyncStatus @default(PENDING)
  httpStatus    Int?            @map("http_status")
  responseBody  Json?           @map("response_body")
  errorMessage  String?         @map("error_message")
  attemptCount  Int             @default(0) @map("attempt_count")
  maxAttempts   Int             @default(5) @map("max_attempts")
  durationMs    Int?            @map("duration_ms")
  lastAttemptAt DateTime?       @db.Timestamptz @map("last_attempt_at")
  nextRetryAt   DateTime?       @db.Timestamptz @map("next_retry_at")
  acknowledgedAt DateTime?      @db.Timestamptz @map("acknowledged_at")
  createdAt     DateTime        @default(now()) @db.Timestamptz @map("created_at")
  updatedAt     DateTime        @updatedAt @db.Timestamptz @map("updated_at")

  teacher       Teacher?        @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  schoolYear    SchoolYear?     @relation(fields: [schoolYearId], references: [id], onDelete: SetNull)

  @@index([status, nextRetryAt], name: "idx_atlas_sync_events_status_retry")
  @@index([teacherId, createdAt], name: "idx_atlas_sync_events_teacher_created_at")
  @@index([schoolYearId, createdAt], name: "idx_atlas_sync_events_sy_created_at")
  @@index([createdAt], name: "idx_atlas_sync_events_created_at")
  @@map("atlas_sync_events")
}

