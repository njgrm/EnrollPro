generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int          @id @default(autoincrement())
  name               String
  email              String       @unique(map: "uq_users_email")
  password           String
  role               Role
  isActive           Boolean      @default(true) @map("is_active")
  lastLoginAt        DateTime?    @map("last_login_at")
  mustChangePassword Boolean      @default(false) @map("must_change_password")
  createdById        Int?         @map("created_by_id")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  encodedApplicants  Applicant[]  @relation("ApplicantEncodedBy")
  auditLogs          AuditLog[]
  enrollments        Enrollment[]
  createdBy          User?        @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers       User[]       @relation("UserCreatedBy")

  @@map("users")
}

model Teacher {
  id             Int       @id @default(autoincrement())
  employeeId     String?   @unique(map: "uq_teachers_employee_id") @map("employee_id")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  middleName     String?   @map("middle_name")
  contactNumber  String?   @map("contact_number")
  specialization String?
  subjects       String[]  @default([])
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  sections       Section[]

  @@map("teachers")
}

model SchoolSettings {
  id                   Int           @id @default(autoincrement())
  schoolName           String        @map("school_name")
  logoPath             String?       @map("logo_path")
  logoUrl              String?       @map("logo_url")
  colorScheme          Json?         @map("color_scheme")
  selectedAccentHsl    String?       @map("selected_accent_hsl")
  activeSchoolYearId   Int?          @map("active_school_year_id")
  activeSchoolYear     SchoolYear?   @relation(fields: [activeSchoolYearId], references: [id])

  @@map("school_settings")
}

model SchoolYear {
  id                 Int              @id @default(autoincrement())
  yearLabel          String           @unique(map: "uq_school_years_year_label") @map("year_label")
  status             SchoolYearStatus @default(DRAFT)
  isActive           Boolean          @default(false) @map("is_active")
  classOpeningDate   DateTime?        @map("class_opening_date")
  classEndDate       DateTime?        @map("class_end_date")
  earlyRegOpenDate   DateTime?        @map("early_reg_open_date")
  earlyRegCloseDate  DateTime?        @map("early_reg_close_date")
  enrollOpenDate     DateTime?        @map("enroll_open_date")
  enrollCloseDate    DateTime?        @map("enroll_close_date")
  isManualOverrideOpen Boolean        @default(false) @map("is_manual_override_open")
  clonedFromId       Int?             @map("cloned_from_id")
  createdAt          DateTime         @default(now()) @map("created_at")
  clonedFrom         SchoolYear?      @relation("SchoolYearClone", fields: [clonedFromId], references: [id])
  clones             SchoolYear[]     @relation("SchoolYearClone")
  applicants         Applicant[]
  enrollments        Enrollment[]
  gradeLevels        GradeLevel[]
  schoolSettings     SchoolSettings[]
  scpConfigs         ScpConfig[]
  strands            Strand[]

  @@map("school_years")
}

model GradeLevel {
  id             Int          @id @default(autoincrement())
  name           String
  displayOrder   Int          @map("display_order")
  schoolYearId   Int          @map("school_year_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  applicants     Applicant[]
  schoolYear     SchoolYear   @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  sections       Section[]

  @@map("grade_levels")
}

model Strand {
  id                      Int            @id @default(autoincrement())
  name                    String
  applicableGradeLevelIds Int[]          @map("applicable_grade_level_ids")
  schoolYearId            Int            @map("school_year_id")
  curriculumType          CurriculumType @default(OLD_STRAND) @map("curriculum_type")
  track                   SHSTrack?
  createdAt               DateTime       @default(now()) @map("created_at")
  applicants              Applicant[]
  schoolYear              SchoolYear     @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)

  @@map("strands")
}

model Section {
  id                Int          @id @default(autoincrement())
  name              String
  maxCapacity       Int          @default(40) @map("max_capacity")
  gradeLevelId      Int          @map("grade_level_id")
  advisingTeacherId Int?         @map("advising_teacher_id")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  enrollments       Enrollment[]
  advisingTeacher   Teacher?     @relation(fields: [advisingTeacherId], references: [id])
  gradeLevel        GradeLevel   @relation(fields: [gradeLevelId], references: [id], onDelete: Cascade)

  @@map("sections")
}

model Applicant {
  id                      Int               @id @default(autoincrement())
  studentPhoto            String?           @map("student_photo")
  lrn                     String?           @db.VarChar(12)
  psaBirthCertNumber      String?           @map("psa_birth_cert_number")
  lastName                String            @map("last_name")
  firstName               String            @map("first_name")
  middleName              String?           @map("middle_name")
  suffix                  String?
  birthDate               DateTime          @db.Date @map("birth_date")
  sex                     Sex
  placeOfBirth            String?           @map("place_of_birth")
  religion                String?
  motherTongue            String?           @map("mother_tongue")
  currentAddress          Json              @map("current_address")
  permanentAddress        Json?             @map("permanent_address")
  motherName              Json              @map("mother_name")
  fatherName              Json              @map("father_name")
  guardianInfo            Json?             @map("guardian_info")
  emailAddress            String?           @map("email_address")
  isIpCommunity           Boolean           @default(false) @map("is_ip_community")
  ipGroupName             String?           @map("ip_group_name")
  is4PsBeneficiary        Boolean           @default(false) @map("is_4ps_beneficiary")
  householdId4Ps          String?           @map("household_id_4ps")
  isBalikAral             Boolean           @default(false) @map("is_balik_aral")
  lastYearEnrolled        String?           @map("last_year_enrolled")
  isLearnerWithDisability Boolean           @default(false) @map("is_learner_with_disability")
  disabilityTypes         String[]          @map("disability_types")
  lastSchoolName          String?           @map("last_school_name")
  lastSchoolId            String?           @map("last_school_id")
  lastGradeCompleted      String?           @map("last_grade_completed")
  schoolYearLastAttended  String?           @map("school_year_last_attended")
  lastSchoolAddress       String?           @map("last_school_address")
  lastSchoolType          String?           @map("last_school_type")
  learnerType             LearnerType       @default(NEW_ENROLLEE) @map("learner_type")
  electiveCluster         String?           @map("elective_cluster")
  isScpApplication        Boolean           @default(false) @map("is_scp_application")
  scpType                 String?           @map("scp_type")
  artField                String?           @map("art_field")
  sportsList              String[]          @map("sports_list")
  foreignLanguage         String?           @map("foreign_language")
  trackingNumber          String            @unique(map: "uq_applicants_tracking_number") @map("tracking_number")
  status                  ApplicationStatus @default(SUBMITTED)
  rejectionReason         String?           @map("rejection_reason")
  gradeLevelId            Int               @map("grade_level_id")
  strandId                Int?              @map("strand_id")
  schoolYearId            Int               @map("school_year_id")
  applicantType           ApplicantType     @default(REGULAR) @map("applicant_type")
  shsTrack                SHSTrack?         @map("shs_track")
  examDate                DateTime?         @map("exam_date")
  examVenue               String?           @map("exam_venue")
  examScore               Float?            @map("exam_score")
  examResult              String?           @map("exam_result")
  examNotes               String?           @map("exam_notes")
  assessmentType          String?           @map("assessment_type")
  interviewDate           DateTime?         @map("interview_date")
  interviewResult         String?           @map("interview_result")
  interviewNotes          String?           @map("interview_notes")
  auditionResult          String?           @map("audition_result")
  tryoutResult            String?           @map("tryout_result")
  natScore                Float?            @map("nat_score")
  grade10ScienceGrade     Float?            @map("grade10_science_grade")
  grade10MathGrade        Float?            @map("grade10_math_grade")
  generalAverage          Float?            @map("general_average")
  isPrivacyConsentGiven   Boolean           @default(false) @map("is_privacy_consent_given")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")
  admissionChannel        AdmissionChannel  @default(ONLINE) @map("admission_channel")
  encodedById             Int?              @map("encoded_by_id")
  specialNeedsCategory    String?           @map("special_needs_category")
  hasPwdId                Boolean           @default(false) @map("has_pwd_id")
  learningModalities      String[]          @map("learning_modalities")
  isTemporarilyEnrolled   Boolean           @default(false) @map("is_temporarily_enrolled")
  schoolYear              SchoolYear        @relation(fields: [schoolYearId], references: [id])
  encodedBy               User?             @relation("ApplicantEncodedBy", fields: [encodedById], references: [id])
  gradeLevel              GradeLevel        @relation(fields: [gradeLevelId], references: [id])
  strand                  Strand?           @relation(fields: [strandId], references: [id])
  documents               Document[]
  checklist               RequirementChecklist?
  emailLogs               EmailLog[]
  enrollment              Enrollment?

  @@index([status, schoolYearId], name: "idx_applicants_status_school_year_id")
  @@index([lrn], name: "idx_applicants_lrn")
  @@index([applicantType, status], name: "idx_applicants_type_status")
  @@index([trackingNumber], name: "idx_applicants_tracking_number")
  @@map("applicants")
}

model Document {
  id               Int            @id @default(autoincrement())
  applicantId      Int            @map("applicant_id")
  documentType     DocumentType   @map("document_type")
  status           DocumentStatus @default(SUBMITTED)
  fileName         String?        @map("file_name")
  originalName     String?        @map("original_name")
  mimeType         String?        @map("mime_type")
  size             Int?
  verificationNote String?        @map("verification_note")
  isPresentedOnly  Boolean        @default(false) @map("is_presented_only")
  uploadedAt       DateTime       @default(now()) @map("uploaded_at")
  verifiedAt       DateTime?      @map("verified_at")
  verifiedById     Int?           @map("verified_by_id")
  applicant        Applicant      @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([applicantId], name: "idx_documents_applicant_id")
  @@map("documents")
}

model RequirementChecklist {
  id                                 Int       @id @default(autoincrement())
  applicantId                        Int       @unique(map: "uq_requirement_checklists_applicant_id") @map("applicant_id")
  isPsaBirthCertPresented            Boolean   @default(false) @map("is_psa_birth_cert_presented")
  isPsaBcOnFile                      Boolean   @default(false) @map("is_psa_bc_on_file")
  isOriginalPsaBcCollected           Boolean   @default(false) @map("is_original_psa_bc_collected")
  isSecondaryBirthProofSubmitted     Boolean   @default(false) @map("is_secondary_birth_proof_submitted")
  isSf9Submitted                     Boolean   @default(false) @map("is_sf9_submitted")
  isSf10Requested                    Boolean   @default(false) @map("is_sf10_requested")
  isGoodMoralPresented               Boolean   @default(false) @map("is_good_moral_presented")
  isPeptAeSubmitted                  Boolean   @default(false) @map("is_pept_ae_submitted")
  isPwdIdPresented                   Boolean   @default(false) @map("is_pwd_id_presented")
  isMedicalEvalSubmitted             Boolean   @default(false) @map("is_medical_eval_submitted")
  isUndertakingSigned                Boolean   @default(false) @map("is_undertaking_signed")
  isConfirmationSlipReceived         Boolean   @default(false) @map("is_confirmation_slip_received")
  isOtherDocSubmitted                Boolean   @default(false) @map("is_other_doc_submitted")
  updatedAt                          DateTime  @updatedAt @map("updated_at")
  applicant                          Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@map("requirement_checklists")
}

model Enrollment {
  id             Int          @id @default(autoincrement())
  applicantId    Int          @unique(map: "uq_enrollments_applicant_id") @map("applicant_id")
  sectionId      Int          @map("section_id")
  schoolYearId   Int          @map("school_year_id")
  enrolledAt     DateTime     @default(now()) @map("enrolled_at")
  enrolledById   Int          @map("enrolled_by_id")
  schoolYear     SchoolYear   @relation(fields: [schoolYearId], references: [id])
  applicant      Applicant    @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  enrolledBy     User         @relation(fields: [enrolledById], references: [id])
  section        Section      @relation(fields: [sectionId], references: [id])

  @@map("enrollments")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  actionType  String   @map("action_type")
  description String
  subjectType String?  @map("subject_type")
  recordId    Int?     @map("record_id")
  ipAddress   String   @db.VarChar(45) @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User?    @relation(fields: [userId], references: [id])

  @@index([actionType], name: "idx_audit_logs_action_type")
  @@index([createdAt], name: "idx_audit_logs_created_at")
  @@map("audit_logs")
}

model EmailLog {
  id           Int          @id @default(autoincrement())
  recipient    String
  subject      String
  trigger      EmailTrigger
  status       EmailStatus  @default(PENDING)
  applicantId  Int?         @map("applicant_id")
  errorMessage String?      @map("error_message")
  attemptedAt  DateTime     @default(now()) @map("attempted_at")
  sentAt       DateTime?    @map("sent_at")
  applicant    Applicant?   @relation(fields: [applicantId], references: [id])

  @@index([status], name: "idx_email_logs_status")
  @@index([trigger], name: "idx_email_logs_trigger")
  @@map("email_logs")
}

model ScpConfig {
  id             Int           @id @default(autoincrement())
  schoolYearId   Int           @map("school_year_id")
  scpType        ApplicantType @map("scp_type")
  isOffered      Boolean       @default(false) @map("is_offered")
  cutoffScore    Float?        @map("cutoff_score")
  examDate       DateTime?     @map("exam_date")
  artFields      String[]      @map("art_fields")
  languages      String[]
  sportsList     String[]      @map("sports_list")
  notes          String?
  schoolYear     SchoolYear    @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)

  @@unique([schoolYearId, scpType], name: "uq_scp_configs_school_year_scp_type")
  @@map("scp_configs")
}

enum Role {
  REGISTRAR
  SYSTEM_ADMIN

  @@map("user_role")
}

enum Sex {
  MALE
  FEMALE

  @@map("sex")
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  FOR_REVISION
  ELIGIBLE
  ASSESSMENT_SCHEDULED
  ASSESSMENT_TAKEN
  PASSED
  PRE_REGISTERED
  TEMPORARILY_ENROLLED
  NOT_QUALIFIED
  ENROLLED
  REJECTED
  WITHDRAWN

  @@map("application_status")
}

enum SchoolYearStatus {
  DRAFT
  UPCOMING
  ACTIVE
  ARCHIVED

  @@map("school_year_status")
}

enum CurriculumType {
  OLD_STRAND
  ELECTIVE_CLUSTER

  @@map("curriculum_type")
}

enum SHSTrack {
  ACADEMIC
  TECHPRO

  @@map("shs_track")
}

enum ApplicantType {
  REGULAR
  STE
  SPA
  SPS
  SPJ
  SPFL
  SPTVE
  STEM_GRADE11

  @@map("applicant_type")
}

enum EmailTrigger {
  APPLICATION_SUBMITTED
  APPLICATION_APPROVED
  APPLICATION_REJECTED
  EXAM_SCHEDULED
  ASSESSMENT_PASSED
  ASSESSMENT_FAILED

  @@map("email_trigger")
}

enum EmailStatus {
  PENDING
  SENT
  FAILED

  @@map("email_status")
}

enum AdmissionChannel {
  ONLINE
  F2F

  @@map("admission_channel")
}

enum DocumentStatus {
  SUBMITTED
  VERIFIED
  REJECTED
  MISSING

  @@map("document_status")
}

enum DocumentType {
  PSA_BIRTH_CERTIFICATE
  SECONDARY_BIRTH_PROOF
  SF9_REPORT_CARD
  SF10_PERMANENT_RECORD
  GOOD_MORAL_CERTIFICATE
  MEDICAL_CERTIFICATE
  MEDICAL_EVALUATION
  PEPT_AE_CERTIFICATE
  PWD_ID
  PSA_MARRIAGE_CERTIFICATE
  UNDERTAKING
  AFFIDAVIT_OF_UNDERTAKING
  CONFIRMATION_SLIP
  OTHERS

  @@map("document_type")
}

enum LearnerType {
  NEW_ENROLLEE
  TRANSFEREE
  RETURNING
  CONTINUING

  @@map("learner_type")
}
